{
  "name": "clawlens",
  "version": "0.2.0",
  "description": "Agent observatory and governance for OpenClaw",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/ index.ts tests/",
