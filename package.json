{
  "name": "@nk3750/openclaw-clawlens",
  "version": "1.0.1",
  "description": "Agent observability and guardrails for OpenClaw",
  "type": "module",
  "main": "dist/index.js",
  "license": "MIT",
  "author": "ClawLens Contributors",
  "homepage": "https://github.com/nk3750/clawlens#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nk3750/clawlens.git"
  },
  "bugs": {
    "url": "https://github.com/nk3750/clawlens/issues"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "agent-observability",
    "audit",
    "risk-scoring",
    "guardrails",
    "ai-safety"
  ],
  "engines": {
    "node": ">=22"
  },
  "openclaw": {
    "extensions": ["./dist/index.js"],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.4.0"
    },
    "build": {
      "openclawVersion": "2026.5.7",
      "pluginSdkVersion": "2026.5.7"
    },
    "install": {
      "minHostVersion": ">=2026.4.0"
    }
  },
  "files": [
    "dist/",
    "dashboard/dist/",
    "openclaw.plugin.json",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/ index.ts tests/",
    "lint:fix": "biome check --write src/ index.ts tests/",
    "check": "vitest run && biome check src/ index.ts tests/",
    "prepublishOnly": "npx tsc -p tsconfig.json && cd dashboard && npm run build"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "minimatch": "^10.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.0.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
