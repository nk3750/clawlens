  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "minimatch": "^10.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
