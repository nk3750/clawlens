{
  "id": "clawlens",
  "name": "ClawLens",
  "description": "Agent observatory and governance for OpenClaw — see everything your agents do, understand risk, enforce when ready",
  "version": "0.1.0",
  "configSchema": {
    "type": "object",
    "properties": {
      "policiesPath": {
        "type": "string",
        "description": "Path to YAML policy file"
      },
      "auditLogPath": {
        "type": "string",
        "description": "Path to JSONL audit log"
      },
      "rateStatePath": {
        "type": "string",
        "description": "Path to rate limiter state file"
      },
      "retention": {
        "type": "string",
        "description": "Audit log retention (e.g. 7d, 30d, 90d)"
      },
      "digest": {
        "type": "object",
        "properties": {
          "schedule": { "type": "string" },
          "channel": { "type": "string" }
        }
      }
    }
  }
}
